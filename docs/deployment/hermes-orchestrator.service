[Unit]
Description=AgentHive Orchestrator — Event-driven agent dispatcher
Documentation=https://github.com/agentroadmap/agentRoadmap
After=network-online.target postgresql.service hermes-gate-pipeline.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/data/code/AgentHive
ExecStart=/usr/bin/env node --import jiti/register scripts/orchestrator.ts
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hermes-orchestrator

# Environment file for database credentials
EnvironmentFile=-%h/.agenthive.env

# Resource limits
MemoryMax=512M
CPUQuota=50%

[Install]
WantedBy=default.target
