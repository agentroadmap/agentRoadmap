[Unit]
Description=AgentHive PipelineCron Gate Worker
Documentation=https://github.com/agentroadmap/agentRoadmap
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/data/code/AgentHive
ExecStart=/usr/bin/env node --import jiti/register scripts/start-gate-pipeline.ts
Restart=on-failure
RestartSec=5
# P254: give PipelineCron up to 3min to drain in-flight gate work on SIGTERM
# before systemd escalates to SIGKILL (default would be 90s).
TimeoutStopSec=180
KillSignal=SIGTERM
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agenthive-gate-pipeline

# Environment file for database credentials (optional)
EnvironmentFile=-%h/.agenthive.env

# Security hardening
NoNewPrivileges=true

[Install]
WantedBy=default.target
